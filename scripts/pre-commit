#!/usr/bin/env bash
set -euo pipefail

echo "==> Running swiftformat lint..."
if ! swiftformat . --lint 2>&1; then
    echo ""
    echo "Lint failed. Run 'swiftformat .' to fix, then re-commit."
    exit 1
fi

echo "==> Running tests..."
if ! swift test --quiet 2>&1; then
    echo ""
    echo "Tests failed. Fix the failures, then re-commit."
    exit 1
fi

echo "==> Pre-commit checks passed."
